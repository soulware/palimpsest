{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "NamesReadWriteDelete",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": ["arn:aws:s3:::{{tenant.bucket}}/names/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
      }
    },
    {
      "Sid": "EventsAppendOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::{{tenant.bucket}}/events/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
      }
    },
    {
      "Sid": "OwnIdentityImmutable",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": ["arn:aws:s3:::{{tenant.bucket}}/coordinators/{{caveat "sub"}}/*"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
      }
    },
    {
      "Sid": "BucketEnumeration",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::{{tenant.bucket}}"],
      "Condition": {
        "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
      }
    }
  ]
}
