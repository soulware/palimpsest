{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "DemoWrite",
    "Effect": "Allow",
    "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
    "Resource": ["arn:aws:s3:::{{tenant.bucket}}/{{request.prefix}}/*"],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
    }
  }]
}
