{
  "Version": "2012-10-17",
  "Statement": [{
    "Sid": "DemoRead",
    "Effect": "Allow",
    "Action": ["s3:GetObject"],
    "Resource": ["arn:aws:s3:::{{tenant.bucket}}/{{request.prefix}}/*"],
    "Condition": {
      "DateLessThan": {"aws:CurrentTime": "{{system.expiry_iso8601}}"}
    }
  }]
}
